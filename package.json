{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "npm run format:js && npm run format:php",
        "format:check": "npm run format:js:check && npm run format:php:check",
        "format:js": "prettier --write \"*.{json,md}\" \"docs/**/*.md\" \"resources/**/*.{css,js,jsx,md}\"",
        "format:js:check": "prettier --check \"*.{json,md}\" \"docs/**/*.md\" \"resources/**/*.{css,js,jsx,md}\"",
        "format:php": "vendor/bin/pint",
        "format:php:check": "vendor/bin/pint --test"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "laravel-vite-plugin": "^3.1",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@inertiajs/react": "^3.4.0",
        "@vitejs/plugin-react": "^6.0.2",
        "lucide-react": "^1.21.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    }
}
